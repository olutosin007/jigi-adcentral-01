# Creative Router HTTP port (default 4000)
PORT=4000

# Meta MCP – for real creative validation (optional; when unset, router uses mock validation)
# Point to the meta-validation-proxy service and use your Meta access token.
META_MCP_BASE_URL=http://localhost:3002
META_MCP_API_KEY=<your-meta-access-token>

# Canva MCP – optional; when unset, router uses mock generation
# CANVA_MCP_BASE_URL=https://api.canva.com/rest
# CANVA_MCP_API_KEY=<your-canva-api-key>

# Reserved for later sprints
# ADOBE_MCP_KEY=
# COMPOSIO_API_KEY=
