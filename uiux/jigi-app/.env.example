# =============================================================================
# JIGI APP - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (Client-safe - bundled into frontend)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# SUPABASE (Server-only - for API routes, NEVER expose to frontend)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# REPLICATE (Server-only - for Flux image generation)
# -----------------------------------------------------------------------------
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your-replicate-token

# -----------------------------------------------------------------------------
# LLM TEXT GENERATION (Server-only - concepts, copy, compliance, prompt refine)
# -----------------------------------------------------------------------------
# Provider selector: openrouter (default) | azure
LLM_PROVIDER=openrouter

# OpenRouter — one key, many models, with built-in fallback.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key
# Model slug (see https://openrouter.ai/models). Must support JSON output.
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional attribution headers shown on the OpenRouter dashboard
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_TITLE=Jigi

# -----------------------------------------------------------------------------
# AZURE OPENAI (LEGACY / OPTIONAL - only used when LLM_PROVIDER=azure)
# -----------------------------------------------------------------------------
# Retained for fallback; safe to leave blank when using OpenRouter.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT_GPT=gpt-4o-mini

# Image generation: use GPT Image family (DALL·E 3 deprecated Mar 2026)
AZURE_OPENAI_DEPLOYMENT_DALLE=gpt-image-1-mini
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-1-mini
AZURE_OPENAI_IMAGE_API_VERSION=2025-04-01-preview

# -----------------------------------------------------------------------------
# AZURE AI FOUNDRY FLUX (Server-only - FLUX.2-flex image generation)
# -----------------------------------------------------------------------------
# From Azure AI Foundry deployment: Target URI + API key (Bearer auth)
# When set, used as primary image route in azure_only mode
# Full Target URI from Azure Foundry deployment. Must use services.ai.azure.com (not cognitiveservices.azure.com)
AZURE_FOUNDRY_FLUX_ENDPOINT=https://your-resource.services.ai.azure.com/providers/blackforestlabs/v1/flux-2-flex?api-version=preview
AZURE_FOUNDRY_FLUX_API_KEY=your-foundry-flux-api-key
# Optional model override (default: flux-2-flex)
# AZURE_FOUNDRY_FLUX_MODEL=flux-2-flex

# -----------------------------------------------------------------------------
# GOOGLE IMAGEN (Server-only - primary free-tier image generation lane)
# -----------------------------------------------------------------------------
# Get your key from Google AI Studio
GOOGLE_AI_API_KEY=your-google-ai-api-key
# Optional custom endpoint base
GOOGLE_IMAGEN_ENDPOINT_BASE=https://generativelanguage.googleapis.com/v1beta
# Optional model overrides by tier
GOOGLE_IMAGEN_MODEL_DRAFT=imagen-4.0-fast-generate-001
GOOGLE_IMAGEN_MODEL_REFINE=imagen-4.0-generate-001
GOOGLE_IMAGEN_MODEL_FINAL=imagen-4.0-ultra-generate-001

# -----------------------------------------------------------------------------
# IMAGE ROUTING GUARDRAILS (Server-only)
# -----------------------------------------------------------------------------
# Provider mode:
# - hybrid: free lanes first (Foundry/Google/Replicate), then optional paid fallback
# - azure_only: force Azure image route while keeping other adapters in code
# Replicate (Flux) is a primary free lane in hybrid mode — the workhorse once
# Azure is decommissioned. Set REPLICATE_API_TOKEN above and keep mode=hybrid.
IMAGE_ROUTING_PROVIDER_MODE=hybrid
# Keep paid fallback off in initial rollout; enable later with a strict cap.
IMAGE_ROUTING_ENABLE_PAID_FALLBACK=false
IMAGE_CAP_DRAFT_DAILY=300
IMAGE_CAP_REFINE_DAILY=120
IMAGE_CAP_FINAL_DAILY=40
IMAGE_CAP_PER_USER_DAILY=24
IMAGE_CAP_PER_CAMPAIGN_DAILY=18
IMAGE_PAID_CAP_GLOBAL_DAILY=12
REPLICATE_IMAGE_MODEL_DRAFT=black-forest-labs/flux-schnell
REPLICATE_IMAGE_MODEL_REFINE=black-forest-labs/flux-dev
REPLICATE_IMAGE_MODEL_FINAL=black-forest-labs/flux-dev
AZURE_OPENAI_IMAGE_MODEL_DRAFT=gpt-image-1-mini
AZURE_OPENAI_IMAGE_MODEL_REFINE=gpt-image-1-mini
AZURE_OPENAI_IMAGE_MODEL_FINAL=gpt-image-1-mini

# -----------------------------------------------------------------------------
# RESEND (Server-only - for transactional email)
# -----------------------------------------------------------------------------
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=Jigi <notifications@jigi.app>

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
VITE_APP_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# CRON (Server-only - for Vercel cron job authentication)
# -----------------------------------------------------------------------------
CRON_SECRET=generate-a-random-32-char-string
